# MedPulse Environment Variables

# The URL of your Supabase project (e.g. https://xyz.supabase.co)
SUPABASE_URL=

# The public anon key (optional, used if service role is not provided)
SUPABASE_KEY=

# The Service Role Key (RECOMMENDED for server-side execution as it bypasses Row-Level Security)
SUPABASE_SERVICE_ROLE_KEY=

# The Google Gemini API key for intelligent recommendations
GEMINI_API_KEY=
